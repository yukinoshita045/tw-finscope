# tw-finscope 環境變數設定

# PostgreSQL 連線字串（必要）
# 本地開發：
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/twfinscope
# Render/Supabase 例子：
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# FastAPI CORS — 允許的前端 origin（可選，已預設允許 *.vercel.app）
CORS_ORIGIN=https://your-app.vercel.app

# 前端：FastAPI 後端 URL（在 frontend/.env 中設定）
# VITE_API_BASE=https://tw-finscope.onrender.com
